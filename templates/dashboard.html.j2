function populateMaqSelect(){
  const sel=document.getElementById('f-maq');
  const mqs=[...new Set((DATA.mensal||[]).map(r=>r.maq))].sort();
  mqs.forEach(m=>{const o=document.createElement('option');o.value=m;o.textContent=m;sel.appendChild(o);});
}

function setDefaultDates(){
  const mn=DATA.mensal||[];if(!mn.length)return;
  const s=[...mn].sort((a,b)=>(a.ano*100+a.mes)-(b.ano*100+b.mes));
  const f=s[0],l=s[s.length-1];
  document.getElementById('f-de').value=`${f.ano}-${String(f.mes).padStart(2,'0')}-01`;
  const ld=new Date(l.ano,l.mes,0).getDate();
  document.getElementById('f-ate').value=`${l.ano}-${String(l.mes).padStart(2,'0')}-${String(ld).padStart(2,'0')}`;
}

fillKPIs();
populateMaqSelect();
setDefaultDates();
initPage('overview');
document.getElementById('btn-aplicar').addEventListener('click',applyFilter);
document.getElementById('btn-limpar').addEventListener('click',resetFilter);
</script>
</body>
</html>
