/* ═══════ FILTROS ═══════ */
function filterMensal(){
  const de=document.getElementById('f-de').value;
  const ate=document.getElementById('f-ate').value;
  const maq=document.getElementById('f-maq').value;
  // Parse manual (evita bug de timezone com new Date())
  const parseYM = s => { const [y,m] = s.split('-').map(Number); return y*100+m; };
  const deYM  = de  ? parseYM(de)  : null;
  const ateYM = ate ? parseYM(ate) : null;
  return (DATA.mensal||[]).filter(r=>{
    const rYM=r.ano*100+r.mes;
    if(deYM  !== null && rYM < deYM ) return false;
    if(ateYM !== null && rYM > ateYM) return false;
    if(maq && r.maq !== maq) return false;
    return true;
  });
}

function rebuildCharts(){
  const pg=document.querySelector('.sb-i.active')?.dataset.page||'overview';
  done[pg]=false;
  initPage(pg);
}

function applyFilter(){
  const filtered=filterMensal();
  if(!filtered.length){alert('Nenhum dado no período / máquina selecionada.');return;}
  const v=computeView(filtered);
  DATA.kpis=v.kpis;DATA.series=v.series;DATA.por_maquina=v.por_maquina;DATA.periodo=v.periodo;
  fillKPIs();
  rebuildCharts();
}

function resetFilter(){
  DATA.kpis=JSON.parse(JSON.stringify(_SNAP.kpis));
  DATA.series=JSON.parse(JSON.stringify(_SNAP.series));
  DATA.por_maquina=JSON.parse(JSON.stringify(_SNAP.por_maquina));
  DATA.periodo=_SNAP.periodo;
  document.getElementById('f-maq').value='';
  setDefaultDates();
  fillKPIs();
  rebuildCharts();
}

