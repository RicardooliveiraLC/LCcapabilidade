<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Capabilidade Produtiva — Label Code</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<style>
:root{
  --sb-bg:#16213E;--sb-t:#94A3B8;--sb-h:rgba(255,255,255,.06);--sb-a:rgba(6,106,171,.22);
  --bg:#F0F4F8;--card:#fff;--bd:#E2E8F0;--text:#1E293B;--t2:#475569;--mu:#94A3B8;
  --bl:#066AAB;--bm:#3B82F6;--bl2:#93C5FD;--bs:#DBEAFE;
  --gn:#10B981;--rd:#EF4444;--am:#F59E0B;
  --sh:0 1px 3px rgba(0,0,0,.06),0 2px 10px rgba(0,0,0,.04);
  --r:12px;--sb:220px;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;font-family:'Montserrat',-apple-system,Segoe UI,Inter,sans-serif;font-size:13px;color:var(--text);background:var(--bg)}
.app{display:flex;height:100vh;overflow:hidden}

/* sidebar */
.sidebar{width:var(--sb);background:var(--sb-bg);display:flex;flex-direction:column;flex-shrink:0}
.sb-logo{padding:22px 18px;display:flex;align-items:center;gap:12px;border-bottom:1px solid rgba(255,255,255,.07)}
.sb-logo .ic{width:34px;height:34px;background:var(--bl);border-radius:8px;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:13px;flex-shrink:0}
.sb-logo .nm{color:#fff;font-weight:700;font-size:12.5px;letter-spacing:.08em}
.sb-logo .nm small{display:block;color:var(--sb-t);font-weight:400;font-size:9.5px;letter-spacing:.16em;margin-top:2px;text-transform:uppercase}
.sb-nav{padding:16px 10px;flex:1;overflow-y:auto}
.sb-grp{margin-bottom:22px}
.sb-grp-t{font-size:9px;letter-spacing:.3em;text-transform:uppercase;color:rgba(148,163,184,.4);padding:0 10px;margin-bottom:8px}
.sb-i{display:flex;align-items:center;gap:10px;padding:10px 10px;border-radius:8px;color:var(--sb-t);font-size:12px;font-weight:500;cursor:pointer;transition:all .15s;margin-bottom:2px;user-select:none}
.sb-i:hover{background:var(--sb-h);color:#fff}
.sb-i.active{background:var(--sb-a);color:#fff}
.sb-i .ico{font-size:14px;width:18px;text-align:center;flex-shrink:0}
.sb-foot{padding:14px 18px;border-top:1px solid rgba(255,255,255,.07);font-size:9.5px;color:rgba(148,163,184,.35);letter-spacing:.12em}

/* main */
.main{flex:1;display:flex;flex-direction:column;overflow:hidden}
.topbar{background:var(--card);border-bottom:1px solid var(--bd);padding:14px 28px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;position:sticky;top:0;z-index:10;gap:12px}
.tp-l .ttl{font-size:17px;font-weight:700}
.tp-l .sub{font-size:11px;color:var(--mu);margin-top:2px}
.tp-r{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.fsel{border:1px solid var(--bd);background:var(--bg);border-radius:8px;padding:7px 11px;font-size:11.5px;color:var(--text);outline:none;font-family:inherit;cursor:pointer}
.fdate{border:1px solid var(--bd);background:var(--bg);border-radius:8px;padding:7px 11px;font-size:11.5px;color:var(--text);outline:none;font-family:inherit}
.flbl{font-size:10px;letter-spacing:.16em;color:var(--mu);text-transform:uppercase;flex-shrink:0}
.fgrp{display:flex;align-items:center;gap:6px}
.bp{background:var(--bl);color:#fff;border:0;border-radius:8px;padding:8px 16px;font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;font-family:inherit}
.bg{background:transparent;color:var(--t2);border:1px solid var(--bd);border-radius:8px;padding:7px 13px;font-size:11px;cursor:pointer;font-family:inherit}
.bp:hover{background:var(--bm)}.bg:hover{background:var(--bg)}
.content{flex:1;overflow-y:auto;padding:24px 28px}
.page{display:none}.page.active{display:block}

/* kpis */
.kg{display:grid;gap:16px;margin-bottom:18px}
.kg.c4{grid-template-columns:repeat(4,1fr)}
.kg.c3{grid-template-columns:repeat(3,1fr)}
.kg.c2{grid-template-columns:repeat(2,1fr)}
.kc{background:var(--card);border-radius:var(--r);padding:18px 20px;box-shadow:var(--sh)}
.kc-h{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:10px}
.kc-lb{font-size:10.5px;color:var(--mu);font-weight:600;letter-spacing:.1em;text-transform:uppercase}
.kc-ic{width:34px;height:34px;border-radius:8px;background:var(--bs);color:var(--bl);display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0}
.kc-v{font-size:26px;font-weight:700;line-height:1}
.kc-v .u{font-size:13px;color:var(--mu);font-weight:500;margin-left:2px}
.kc-d{margin-top:8px;font-size:11px;display:flex;align-items:center;gap:5px}
.kc-d .up{color:var(--gn);font-weight:600}.kc-d .dn{color:var(--rd);font-weight:600}.kc-d .ne{color:var(--mu)}
.kc-d .vs{color:var(--mu)}

/* charts */
.cg{display:grid;gap:18px;margin-bottom:20px}
.cg.c2{grid-template-columns:1fr 1fr}
.cg.c3{grid-template-columns:1fr 1fr 1fr}
.cg.c1{grid-template-columns:1fr}
.cc{background:var(--card);border-radius:var(--r);padding:20px 22px;box-shadow:var(--sh)}
.cc .ct{font-size:13px;font-weight:600}
.cc .cs{font-size:11px;color:var(--mu);margin-top:3px;margin-bottom:16px}
.cb{position:relative;width:100%}
.cb.h200{height:200px}.cb.h220{height:220px}.cb.h240{height:240px}.cb.h180{height:180px}

/* donut layout */
.dl{display:grid;grid-template-columns:165px 1fr;gap:20px;align-items:center;height:220px}
.dw{position:relative;width:160px;height:160px}
.dc{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;pointer-events:none}
.dc .dv{font-size:18px;font-weight:800}.dc .dl2{font-size:9px;letter-spacing:.22em;color:var(--mu);text-transform:uppercase;margin-top:2px}
.dleg{display:flex;flex-direction:column;gap:14px}
.dlr{display:flex;align-items:center;gap:10px}
.dld{width:10px;height:10px;border-radius:3px;flex-shrink:0}
.dln{font-size:11.5px;color:var(--t2);font-weight:500}
.dlv{font-size:14px;font-weight:700}.dlp{font-size:11px;color:var(--mu);margin-left:4px;font-weight:400}

/* cap machine */
.cml{display:flex;flex-direction:column;gap:13px}
.cmr{display:grid;grid-template-columns:120px 1fr 52px;align-items:center;gap:14px}
.cmr .cnm{font-size:12px;font-weight:600}.cmr .csb{font-size:10px;color:var(--mu);margin-top:1px}
.cbs{display:flex;flex-direction:column;gap:5px}
.cb2{height:8px;border-radius:4px;background:var(--bg);overflow:hidden;position:relative}
.cb2 span{position:absolute;left:0;top:0;bottom:0;border-radius:4px}
.cbl{display:flex;justify-content:space-between;font-size:9.5px;color:var(--mu);margin-top:2px}
.cmr .cp{font-size:15px;font-weight:800;text-align:right}

/* config table */
.cfc{background:var(--card);border-radius:var(--r);padding:24px;box-shadow:var(--sh);max-width:720px;margin-bottom:20px}
.cfc h3{font-size:14px;font-weight:700;margin-bottom:4px}
.cfc .cfs{font-size:11.5px;color:var(--mu);margin-bottom:18px}
.cft{width:100%;border-collapse:collapse;font-size:12.5px}
.cft th{text-align:left;padding:8px 10px;font-size:9.5px;letter-spacing:.2em;text-transform:uppercase;color:var(--mu);border-bottom:2px solid var(--bd);font-weight:600}
.cft td{padding:10px 10px;border-bottom:1px solid var(--bd);color:var(--t2)}
.cft tbody tr:last-child td{border-bottom:0}
.cft tbody tr:hover td{background:var(--bs)}
.tdm{font-weight:600;color:var(--text)}
.tdtot{font-weight:700;border-top:2px solid var(--bd);color:var(--text)}
.cnote{margin-top:16px;padding:12px 16px;background:var(--bs);border-radius:8px;border-left:3px solid var(--bl);font-size:11.5px;color:var(--bl)}
</style>
</head>
<body>
<div class="app">

<!-- ══════ SIDEBAR ══════ -->
<aside class="sidebar">
  <div class="sb-logo">
    <div class="ic">LC</div>
    <div class="nm">LABEL CODE<small>Capabilidade Produtiva</small></div>
  </div>
  <nav class="sb-nav">
    <div class="sb-grp">
      <div class="sb-grp-t">Painel</div>
      <div class="sb-i active" data-page="overview"><span class="ico">📊</span> Visão Geral</div>
      <div class="sb-i" data-page="produtividade"><span class="ico">⚡</span> Produtividade</div>
      <div class="sb-i" data-page="capabilidade"><span class="ico">📈</span> Capabilidade</div>
      <div class="sb-i" data-page="manutencao"><span class="ico">🔧</span> Manutenção</div>
    </div>
    <div class="sb-grp">
      <div class="sb-grp-t">Sistema</div>
      <div class="sb-i" data-page="config"><span class="ico">⚙</span> Configurações</div>
    </div>
  </nav>
  <div class="sb-foot" id="atualizado">v1.0 · dados fictícios</div>
</aside>

<!-- ══════ MAIN ══════ -->
<div class="main">
  <div class="topbar">
    <div class="tp-l">
      <div class="ttl" id="pgTitle">Visão Geral</div>
      <div class="sub" id="pgSub">jan 2026 – jun 2026 · todas as máquinas</div>
    </div>
    <div class="tp-r">
      <div class="fgrp">
        <span class="flbl">de</span><input class="fdate" type="date" id="f-de"/>
        <span class="flbl">até</span><input class="fdate" type="date" id="f-ate"/>
      </div>
      <select class="fsel" id="f-maq">
        <option value="">Todas as máquinas</option>
      </select>
      <button class="bp" id="btn-aplicar">Aplicar</button>
      <button class="bg" id="btn-limpar">Limpar</button>
    </div>
  </div>

  <div class="content">

    <!-- ══ PAGE: VISÃO GERAL ══ -->
    <div class="page active" id="page-overview">
      <div class="kg c4">
        <div class="kc"><div class="kc-h"><span class="kc-lb">% Produtivo</span><div class="kc-ic">⏱</div></div>
          <div class="kc-v" id="ov-pct-prod">—</div>
          <div class="kc-d" id="ov-d-pct-prod"></div></div>
        <div class="kc"><div class="kc-h"><span class="kc-lb">% Capabilidade</span><div class="kc-ic">▣</div></div>
          <div class="kc-v" id="ov-pct-cap">—</div>
          <div class="kc-d" id="ov-d-pct-cap"></div></div>
        <div class="kc"><div class="kc-h"><span class="kc-lb">H. Produtivas</span><div class="kc-ic">✓</div></div>
          <div class="kc-v" id="ov-hrs-prod">—</div>
          <div class="kc-d" id="ov-d-hrs-prod"></div></div>
        <div class="kc"><div class="kc-h"><span class="kc-lb">H. Improdutivas</span><div class="kc-ic">✕</div></div>
          <div class="kc-v" id="ov-hrs-imp">—</div>
          <div class="kc-d" id="ov-d-hrs-imp"></div></div>
      </div>
      <div class="kg c4">
        <div class="kc"><div class="kc-h"><span class="kc-lb">Cap. Total Disponível</span><div class="kc-ic">∑</div></div>
          <div class="kc-v" id="ov-cap-tot">—</div>
          <div class="kc-d"><span class="ne">—</span><span class="vs">período completo</span></div></div>
        <div class="kc"><div class="kc-h"><span class="kc-lb">Cap. Utilizada</span><div class="kc-ic">▤</div></div>
          <div class="kc-v" id="ov-cap-util">—</div>
          <div class="kc-d" id="ov-d-cap-util"></div></div>
        <div class="kc"><div class="kc-h"><span class="kc-lb">% Setup</span><div class="kc-ic">⚙</div></div>
          <div class="kc-v" id="ov-pct-setup">—</div>
          <div class="kc-d" id="ov-d-pct-setup"></div></div>
        <div class="kc"><div class="kc-h"><span class="kc-lb">H. Extras</span><div class="kc-ic">⏲</div></div>
          <div class="kc-v" id="ov-hrs-extra">—</div>
          <div class="kc-d" id="ov-d-hrs-extra"></div></div>
      </div>
      <div class="cg c2">
        <div class="cc"><div class="ct">% Capabilidade por Mês</div><div class="cs">últimos 6 meses · tendência</div>
          <div class="cb h220"><canvas id="ov-cap"></canvas></div></div>
        <div class="cc"><div class="ct">H. Disponíveis × H. Apontadas</div><div class="cs">jornada disponível vs. total apontado por mês</div>
          <div class="cb h220"><canvas id="ov-horas"></canvas></div></div>
      </div>
    </div>

    <!-- ══ PAGE: PRODUTIVIDADE ══ -->
    <div class="page" id="page-produtividade">
      <div class="kg c4">
        <div class="kc"><div class="kc-h"><span class="kc-lb">% Produtivo</span><div class="kc-ic">⏱</div></div>
          <div class="kc-v" id="pr-pct-prod">—</div>
          <div class="kc-d" id="pr-d-pct-prod"></div></div>
        <div class="kc"><div class="kc-h"><span class="kc-lb">H. Produtivas</span><div class="kc-ic">✓</div></div>
          <div class="kc-v" id="pr-hrs-prod">—</div>
          <div class="kc-d" id="pr-d-hrs-prod"></div></div>
        <div class="kc"><div class="kc-h"><span class="kc-lb">H. Improdutivas</span><div class="kc-ic">✕</div></div>
          <div class="kc-v" id="pr-hrs-imp">—</div>
          <div class="kc-d" id="pr-d-hrs-imp"></div></div>
        <div class="kc"><div class="kc-h"><span class="kc-lb">Metros Produzidos</span><div class="kc-ic">📐</div></div>
          <div class="kc-v" id="pr-metros">—</div>
          <div class="kc-d" id="pr-d-metros"></div></div>
      </div>
      <div class="kg c2">
        <div class="kc"><div class="kc-h"><span class="kc-lb">H. de Setup</span><div class="kc-ic">⚙</div></div>
          <div class="kc-v" id="pr-hrs-setup">—</div>
          <div class="kc-d" id="pr-d-hrs-setup"></div></div>
        <div class="kc"><div class="kc-h"><span class="kc-lb">H. Extras</span><div class="kc-ic">⏲</div></div>
          <div class="kc-v" id="pr-hrs-extra">—</div>
          <div class="kc-d" id="pr-d-hrs-extra"></div></div>
      </div>
      <div class="cg c2">
        <div class="cc"><div class="ct">Tempo Produtivo por Mês</div><div class="cs">horas produtivas · 6 meses</div>
          <div class="cb h220"><canvas id="pr-tempo"></canvas></div></div>
        <div class="cc"><div class="ct">H. Produtivas × Improdutivas</div><div class="cs">distribuição total do período</div>
          <div class="dl">
            <div class="dw"><canvas id="pr-donut"></canvas>
              <div class="dc"><div class="dv" id="pr-donut-total">—</div><div class="dl2">total</div></div></div>
            <div class="dleg" id="pr-dleg"></div>
          </div></div>
      </div>
      <div class="cg c2">
        <div class="cc"><div class="ct">Horas de Setup por Mês</div><div class="cs">evolução mensal · 6 meses</div>
          <div class="cb h220"><canvas id="pr-setup"></canvas></div></div>
        <div class="cc"><div class="ct">Horas Extras Apontadas</div><div class="cs">por mês · barras escuras ≥ 60h</div>
          <div class="cb h220"><canvas id="pr-extra"></canvas></div></div>
      </div>
    </div>

    <!-- ══ PAGE: CAPABILIDADE ══ -->
    <div class="page" id="page-capabilidade">
      <div class="kg c3">
        <div class="kc"><div class="kc-h"><span class="kc-lb">% Capabilidade Geral</span><div class="kc-ic">▣</div></div>
          <div class="kc-v" id="cp-pct-cap">—</div>
          <div class="kc-d" id="cp-d-pct-cap"></div></div>
        <div class="kc"><div class="kc-h"><span class="kc-lb">Cap. Total Disponível</span><div class="kc-ic">∑</div></div>
          <div class="kc-v" id="cp-cap-tot">—</div>
          <div class="kc-d"><span class="ne">—</span><span class="vs">h. apontadas × vel. ref.</span></div></div>
        <div class="kc"><div class="kc-h"><span class="kc-lb">Cap. Real Utilizada</span><div class="kc-ic">▤</div></div>
          <div class="kc-v" id="cp-cap-util">—</div>
          <div class="kc-d" id="cp-d-cap-util"></div></div>
      </div>
      <div class="cg c2">
        <div class="cc"><div class="ct">% Capabilidade por Mês</div><div class="cs">evolução mensal · 6 meses</div>
          <div class="cb h240"><canvas id="cp-pct"></canvas></div></div>
        <div class="cc">
          <div class="ct">Capabilidade Total × Utilizada por Máquina</div>
          <div class="cs">
            <span style="display:inline-block;width:10px;height:8px;border-radius:2px;background:var(--bs);vertical-align:middle;margin-right:3px"></span>total disponível&ensp;
            <span style="display:inline-block;width:10px;height:8px;border-radius:2px;background:var(--bl);vertical-align:middle;margin-right:3px"></span>real utilizado
          </div>
          <div class="cml" id="cp-maq-list"></div>
        </div>
      </div>
    </div>

    <!-- ══ PAGE: MANUTENÇÃO ══ -->
    <div class="page" id="page-manutencao">
      <div class="kg c3">
        <div class="kc"><div class="kc-h"><span class="kc-lb">H. Preventiva</span><div class="kc-ic">🛡</div></div>
          <div class="kc-v" id="mn-hrs-prev">—</div>
          <div class="kc-d" id="mn-d-hrs-prev"></div></div>
        <div class="kc"><div class="kc-h"><span class="kc-lb">H. Corretiva</span><div class="kc-ic">🔧</div></div>
          <div class="kc-v" id="mn-hrs-corr">—</div>
          <div class="kc-d" id="mn-d-hrs-corr"></div></div>
        <div class="kc"><div class="kc-h"><span class="kc-lb">% Manutenção / Disp.</span><div class="kc-ic">%</div></div>
          <div class="kc-v" id="mn-pct-manut">—</div>
          <div class="kc-d"><span class="ne">—</span><span class="vs">prev + corr / h. disponíveis</span></div></div>
      </div>
      <div class="cg c2">
        <div class="cc"><div class="ct">Manutenção Preventiva por Mês</div><div class="cs">horas · 6 meses</div>
          <div class="cb h220"><canvas id="mn-prev"></canvas></div></div>
        <div class="cc"><div class="ct">Manutenção Corretiva por Mês</div><div class="cs">horas · 6 meses</div>
          <div class="cb h220"><canvas id="mn-corr"></canvas></div></div>
      </div>
      <div class="cg c1">
        <div class="cc">
          <div class="ct">% Manutenção vs. Tempo Total Disponível</div>
          <div class="cs">preventiva, corretiva e total como % das horas disponíveis · 6 meses</div>
          <div class="cb h220"><canvas id="mn-pct"></canvas></div>
        </div>
      </div>
    </div>

    <!-- ══ PAGE: CONFIGURAÇÕES ══ -->
    <div class="page" id="page-config">

      <!-- Velocidades das Máquinas -->
      <div class="cfc">
        <h3>Velocidades de Referência das Máquinas</h3>
        <div class="cfs">Lido de <code style="background:var(--bg);padding:2px 6px;border-radius:4px;font-size:11px">config/config_maq.xlsx</code>. Para alterar, edite o arquivo e reexecute.</div>
        <table class="cft">
          <thead><tr><th>Máquina</th><th>Vel. Referência (m/min)</th><th>Cap./hora (m/h)</th><th>Cap. jornada 9h (m/dia)</th></tr></thead>
          <tbody id="cfg-maq-body"></tbody>
        </table>
        <div class="cnote">📁 Edite <b>config/config_maq.xlsx</b> para alterar as velocidades. O dashboard atualiza na próxima execução.</div>
      </div>

      <!-- Dias Úteis -->
      <div class="cfc">
        <h3>Dias Úteis — Vinhedo / SP · 2026</h3>
        <div class="cfs">Lido de <code style="background:var(--bg);padding:2px 6px;border-radius:4px;font-size:11px">config/dias_uteis.xlsx</code>. Para alterar, edite o arquivo e reexecute.</div>
        <table class="cft">
          <thead><tr><th>Mês</th><th>Dias Úteis</th><th>H. Disponíveis</th><th>Feriados / Observação</th></tr></thead>
          <tbody id="cfg-dias-body"></tbody>
          <tfoot><tr>
            <td class="tdm tdtot" style="padding:10px 10px">Total 2026</td>
            <td class="tdtot" id="cfg-tot-d">—</td>
            <td class="tdtot" id="cfg-tot-h">—</td>
            <td class="tdtot">—</td>
          </tr></tfoot>
        </table>
        <div class="cnote">📁 Edite <b>config/dias_uteis.xlsx</b> para ajustar feriados e jornadas.</div>
      </div>
    </div>

  </div><!-- /content -->
</div><!-- /main -->
</div><!-- /app -->

<script>
/* DATA - substituído pelo Python */
const DATA = __DATA_PLACEHOLDER__;

const MESES_PT = ["Jan","Fev","Mar","Abr","Mai","Jun","Jul","Ago","Set","Out","Nov","Dez"];

/* Snapshot inicial para reset */
const _SNAP = {
  kpis:        JSON.parse(JSON.stringify(DATA.kpis)),
  series:      JSON.parse(JSON.stringify(DATA.series)),
  por_maquina: JSON.parse(JSON.stringify(DATA.por_maquina)),
  periodo:     DATA.periodo,
};

/* ═══════ HELPERS ═══════ */
const fmtM = n => n>=1e6?(n/1e6).toFixed(2).replace('.',',')+'M m':
                  n>=1e3?(n/1e3).toFixed(0)+'k m':n+' m';
const fmtH = n => (+n).toLocaleString('pt-BR')+'<span class="u">h</span>';
const fmtP = n => (+n).toFixed(1).replace('.',',')+'<span class="u">%</span>';
const delta = (v,unit='',inv=false)=>{
  if(!v) return `<span class="ne">—</span><span class="vs">vs. mês anterior</span>`;
  const up=inv?v<0:v>0, cls=up?'up':'dn', sign=v>0?'+':'';
  return `<span class="${cls}">${v>0?'▲':'▼'} ${sign}${unit==='%'?Math.abs(v).toFixed(1).replace('.',',')+'%':Math.abs(v).toLocaleString('pt-BR')+(unit||'')}</span><span class="vs">vs. mês anterior</span>`;
};

/* ═══════ COMPUTA VIEW A PARTIR DE REGISTROS MENSAIS ═══════ */
function computeView(records) {
  const mm = new Map();
  records.forEach(r => {
    const k = r.ano*100+r.mes;
    if (!mm.has(k)) mm.set(k,{ano:r.ano,mes:r.mes,
      label:MESES_PT[r.mes-1]+' '+String(r.ano).slice(-2),
      prod:0,prev:0,corr:0,setup:0,outros:0,disp:0,apont:0,extra:0,metros:0,cap_tot:0});
    const t=mm.get(k);
    t.prod+=r.prod;t.prev+=r.prev;t.corr+=r.corr;t.setup+=r.setup;
    t.outros+=r.outros;t.disp+=r.disp;t.apont+=r.apont;t.extra+=r.extra;
    t.metros+=r.metros;t.cap_tot+=r.cap_tot;
  });
  const ms=[...mm.values()].sort((a,b)=>(a.ano*100+a.mes)-(b.ano*100+b.mes));
  const series={
    labels:   ms.map(m=>m.label),
    pct_cap:  ms.map(m=>m.cap_tot>0?+((m.metros/m.cap_tot*100).toFixed(2)):0),
    hrs_prod: ms.map(m=>+m.prod.toFixed(2)),
    hrs_disp: ms.map(m=>+m.disp.toFixed(2)),
    hrs_apont:ms.map(m=>+m.apont.toFixed(2)),
    hrs_prev: ms.map(m=>+m.prev.toFixed(2)),
    hrs_corr: ms.map(m=>+m.corr.toFixed(2)),
    hrs_setup:ms.map(m=>+m.setup.toFixed(2)),
    hrs_extra:ms.map(m=>+m.extra.toFixed(2)),
    pct_prev: ms.map(m=>m.disp>0?+((m.prev/m.disp*100).toFixed(2)):0),
    pct_corr: ms.map(m=>m.disp>0?+((m.corr/m.disp*100).toFixed(2)):0),
    pct_manut:ms.map(m=>m.disp>0?+(((m.prev+m.corr)/m.disp*100).toFixed(2)):0),
  };
  const tot=records.reduce((a,r)=>{
    a.prod+=r.prod;a.prev+=r.prev;a.corr+=r.corr;a.setup+=r.setup;
    a.outros+=r.outros;a.disp+=r.disp;a.apont+=r.apont;a.extra+=r.extra;
    a.metros+=r.metros;a.cap_tot+=r.cap_tot;return a;
  },{prod:0,prev:0,corr:0,setup:0,outros:0,disp:0,apont:0,extra:0,metros:0,cap_tot:0});
  const ta=tot.apont,imp=ta-tot.prod;
  const kpis={
    pct_produtivo:ta>0?+((tot.prod/ta*100).toFixed(2)):0,
    pct_cap:tot.cap_tot>0?+((tot.metros/tot.cap_tot*100).toFixed(2)):0,
    hrs_prod:+tot.prod.toFixed(2),hrs_improd:+imp.toFixed(2),
    cap_total_m:Math.round(tot.cap_tot),cap_util_m:Math.round(tot.metros),
    metros_prod:Math.round(tot.metros),
    pct_setup:ta>0?+((tot.setup/ta*100).toFixed(2)):0,
    hrs_extra:+tot.extra.toFixed(2),hrs_prev:+tot.prev.toFixed(2),
    hrs_corr:+tot.corr.toFixed(2),hrs_setup:+tot.setup.toFixed(2),
    pct_manut:tot.disp>0?+(((tot.prev+tot.corr)/tot.disp*100).toFixed(2)):0,
    d_pct_produtivo:0,d_pct_cap:0,d_hrs_prod:0,d_hrs_improd:0,
    d_cap_util_pct:0,d_pct_setup:0,d_hrs_extra:0,
    d_hrs_prev:0,d_hrs_corr:0,d_hrs_setup:0,d_metros_pct:0,
  };
  if(ms.length>=2){
    const c=ms[ms.length-1],a=ms[ms.length-2],taC=c.apont,taA=a.apont;
    kpis.d_pct_produtivo=+((taC>0?c.prod/taC*100:0)-(taA>0?a.prod/taA*100:0)).toFixed(2);
    kpis.d_pct_cap=+((c.cap_tot>0?c.metros/c.cap_tot*100:0)-(a.cap_tot>0?a.metros/a.cap_tot*100:0)).toFixed(2);
    kpis.d_hrs_prod=+(c.prod-a.prod).toFixed(2);
    kpis.d_hrs_improd=+((c.apont-c.prod)-(a.apont-a.prod)).toFixed(2);
    kpis.d_cap_util_pct=a.metros>0?+((c.metros-a.metros)/a.metros*100).toFixed(2):0;
    kpis.d_pct_setup=+((taC>0?c.setup/taC*100:0)-(taA>0?a.setup/taA*100:0)).toFixed(2);
    kpis.d_hrs_extra=+(c.extra-a.extra).toFixed(2);
    kpis.d_hrs_prev=+(c.prev-a.prev).toFixed(2);
    kpis.d_hrs_corr=+(c.corr-a.corr).toFixed(2);
    kpis.d_hrs_setup=+(c.setup-a.setup).toFixed(2);
    kpis.d_metros_pct=a.metros>0?+((c.metros-a.metros)/a.metros*100).toFixed(2):0;
  }
  const velMap={};DATA.por_maquina.forEach(m=>velMap[m.nm]=m.vel);
  const maqMap={};
  records.forEach(r=>{
    if(!maqMap[r.maq])maqMap[r.maq]={h:0,cap_tot:0,cap_real:0};
    maqMap[r.maq].h+=r.apont;maqMap[r.maq].cap_tot+=r.cap_tot;maqMap[r.maq].cap_real+=r.metros;
  });
  const por_maquina=Object.entries(maqMap).map(([nm,v])=>({
    nm,vel:velMap[nm]||0,h:+v.h.toFixed(2),
    cap_tot:Math.round(v.cap_tot),cap_real:Math.round(v.cap_real),
    pct_cap:v.cap_tot>0?Math.round(v.cap_real/v.cap_tot*100):0
  })).sort((a,b)=>b.pct_cap-a.pct_cap);
  const lbs=series.labels;
  const periodo=lbs.length?(lbs.length===1?lbs[0]:lbs[0]+' – '+lbs[lbs.length-1]):'—';
  return {kpis,series,por_maquina,periodo};
}

